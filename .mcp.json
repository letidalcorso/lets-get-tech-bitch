{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--browser", "chromium", "--executable-path", "/opt/pw-browsers/chromium-1194/chrome-linux/chrome", "--headless", "--allowed-origins", "*", "--config", "_opensquad/config/playwright.config.json"]
    },
    "figma": {
      "command": "npx",
      "args": ["figma-developer-mcp", "--stdio"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "${FIGMA_ACCESS_TOKEN}"
      }
    }
  }
}
